# CEX Balance Skill - API Configuration
# Copy this file to .env and add your READ-ONLY API keys

# Binance (read-only permissions)
BINANCE_API_KEY=
BINANCE_SECRET=

# Coinbase (read-only permissions)
COINBASE_API_KEY=
COINBASE_SECRET=

# OKX (read-only permissions)
OKX_API_KEY=
OKX_SECRET=
OKX_PASSPHRASE=

# Bybit (read-only permissions)
BYBIT_API_KEY=
BYBIT_SECRET=

# Bitget (read-only permissions)
BITGET_API_KEY=
BITGET_SECRET=
BITGET_PASSPHRASE=

# Gate.io (read-only permissions)
GATE_API_KEY=
GATE_SECRET=

# KuCoin (read-only permissions)
KUCOIN_API_KEY=
KUCOIN_SECRET=
KUCOIN_PASSPHRASE=

# IMPORTANT:
# - Only configure exchanges you use
# - Use READ-ONLY API keys ONLY
# - Never enable trading or withdrawal permissions
# - Keep this file secure and never commit it to git
