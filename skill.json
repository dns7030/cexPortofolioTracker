{
  "name": "cex-balance",
  "description": "Check cryptocurrency exchange balances across Binance, KuCoin, and Gate.io",
  "version": "1.0.0",
  "author": "dns7030",
  "command": "node dist/index.js",
  "category": "web3-tools",
  "tags": ["crypto", "cryptocurrency", "exchange", "portfolio", "binance", "kucoin", "gateio", "web3", "defi", "trading", "balance"],
  "repository": "https://github.com/dns7030/cexPortofolioTracker",
  "branch": "skill",
  "license": "MIT",
  "env_vars": {
    "BINANCE_API_KEY": {
      "description": "Binance API key (read-only)",
      "required": false
    },
    "BINANCE_SECRET": {
      "description": "Binance API secret",
      "required": false
    },
    "KUCOIN_API_KEY": {
      "description": "KuCoin API key (read-only)",
      "required": false
    },
    "KUCOIN_SECRET": {
      "description": "KuCoin API secret",
      "required": false
    },
    "KUCOIN_PASSPHRASE": {
      "description": "KuCoin API passphrase",
      "required": false
    },
    "GATE_API_KEY": {
      "description": "Gate.io API key (read-only)",
      "required": false
    },
    "GATE_SECRET": {
      "description": "Gate.io API secret",
      "required": false
    }
  },
  "usage": "Check your crypto exchange balances",
  "examples": [
    "/cex-balance - Show all configured exchange balances",
    "/cex-balance binance - Show only Binance balances",
    "/cex-balance --summary - Show total portfolio value"
  ]
}
